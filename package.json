{
  "name": "offgrid-pay",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest --verbose",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "@reduxjs/toolkit": "^2.0.1",
    "buffer": "^6.0.3",
    "ethers": "^6.9.0",
    "react": "18.2.0",
    "react-native": "0.73.2",
    "react-native-ble-plx": "^3.1.2",
    "react-native-gesture-handler": "^2.14.0",
    "react-native-keychain": "^8.2.0",
    "react-native-qrcode-svg": "^6.3.1",
    "react-native-safe-area-context": "^4.8.2",
    "react-native-screens": "^3.29.0",
    "react-native-svg": "^14.1.0",
    "react-native-uuid": "^2.0.2",
    "react-redux": "^9.0.4"
  },
  "devDependencies": {
    "@babel/core": "^7.23.7",
    "@babel/preset-env": "^7.23.7",
    "@babel/runtime": "^7.23.7",
    "@react-native/babel-preset": "^0.73.19",
    "@react-native/eslint-config": "^0.73.2",
    "@react-native/metro-config": "^0.73.3",
    "@react-native/typescript-config": "^0.73.1",
    "@types/jest": "^29.5.11",
    "@types/react": "^18.2.45",
    "@types/react-native": "^0.73.0",
    "@types/react-test-renderer": "^18.0.7",
    "babel-jest": "^29.7.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "react-test-renderer": "18.2.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": ["ts", "tsx", "js", "jsx", "json"],
    "transform": {
      "^.+\\.(ts|tsx)$": "ts-jest",
      "^.+\\.js$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|react-native-uuid|react-native-svg|react-native-qrcode-svg|immer|@reduxjs|react-redux)/)"
    ],
    "testMatch": ["**/__tests__/**/*.test.(ts|tsx)"],
    "moduleNameMapper": {
      "^react-native-ble-plx$": "<rootDir>/src/services/ble/__mocks__/react-native-ble-plx.ts",
      "^react-native-keychain$": "<rootDir>/src/services/wallet/__mocks__/react-native-keychain.ts"
    }
  }
}
